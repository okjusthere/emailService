# Resend API
RESEND_API_KEY=re_xxxxxxxxxxxx
FROM_EMAIL=recruit@yourdomain.com
FROM_NAME=Your Company
REPLY_TO_EMAIL=recruit@yourdomain.com

# API Authentication
API_SECRET=your-secret-key-here

# Server
PORT=3000
BASE_URL=http://localhost:3000

# Sending Schedule
DAILY_SEND_COUNT=5000
BATCH_SIZE=100
SEND_CRON=0 14 * * *
# 0 14 * * * = UTC 14:00 = ET 10:00 AM

# IP Warmup (set the date you start sending, auto-limits volume for 14 days)
SEND_START_DATE=2026-03-25

# Company Info (CAN-SPAM required)
COMPANY_NAME=Your Company Inc.
COMPANY_ADDRESS=123 Main St, City, State ZIP

# Resend Webhook
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
